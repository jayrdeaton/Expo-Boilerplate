{
  "name": "expo-boilerplate",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "expo lint .",
    "fix": "expo lint . --fix",
    "check": "tsc",
    "doctor": "expo install --fix && expo-doctor",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "start": "expo start",
    "client": "expo start --dev-client",
    "reset": "expo start -c",
    "prebuild": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --clean --platform android",
    "prebuild:ios": "expo prebuild --clean --platform ios",
    "build:simulator": "eas build --profile simulator",
    "build:client": "eas build --profile client",
    "build:development": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production",
    "fingerprint:compare": "eas fingerprint:compare",
    "run": "eas build:run",
    "update": "eas update",
    "update:bump": "node ./scripts/bump-ota-version.mjs",
    "submit": "eas submit",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/drawer": "^7.9.6",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/stack": "^7.8.7",
    "@reduxjs/toolkit": "^2.11.2",
    "expo": "^55.0.8",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.10",
    "expo-blur": "~55.0.10",
    "expo-camera": "~55.0.11",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-device": "~55.0.10",
    "expo-font": "^55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "^55.0.6",
    "expo-image-picker": "~55.0.13",
    "expo-keep-awake": "^55.0.4",
    "expo-linking": "~55.0.8",
    "expo-media-library": "~55.0.10",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.15",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-pager-view": "^8.0.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "react-redux": "^9.2.0",
    "reanimated-color-picker": "^4.2.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-native-base64": "^0.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.0",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "expo-doctor": "^1.18.13",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.2"
  }
}
