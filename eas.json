      "developmentClient": true,
      "distribution": "internal",
      "channel": "client"
    },
    "development": {
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "channel": "development",
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "channel": "preview"
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
